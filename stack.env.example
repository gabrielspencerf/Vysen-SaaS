# ---------------------------------------------------------------------------
# Stack Swarm / Portainer — template SEM segredos reais
# Copie para: stack.env (local/VPS) e preencha. Não commitar stack.env.
# ---------------------------------------------------------------------------
#
# ATENÇÃO — SEGREDOS SENSÍVEIS migraram para Docker secrets (mais seguro,
# não aparecem em `docker service inspect`). Crie no manager ANTES do deploy:
#
#   printf '%s' '<senha-postgres-forte>'  | docker secret create postgres_password -
#   openssl rand -hex 32 | tr -d '\n'     | docker secret create session_secret -
#   openssl rand -hex 32 | tr -d '\n'     | docker secret create config_encryption_key -
#   openssl rand -hex 32 | tr -d '\n'     | docker secret create integrations_encryption_key -
#   printf '%s' '<senha-admin-inicial>'   | docker secret create seed_admin_password -
#
# As variáveis POSTGRES_PASSWORD, SESSION_SECRET, CONFIG_ENCRYPTION_KEY,
# INTEGRATIONS_ENCRYPTION_KEY e SEED_ADMIN_PASSWORD abaixo continuam aqui APENAS
# como referência para deploys legados (compose/dev). Em Swarm, os YAMLs já lêem
# de /run/secrets/* — você NÃO precisa colocar valor real neste arquivo.
# ---------------------------------------------------------------------------

# Imagem da aplicacao (registry/tag apos build)
# Imagem publicada no GHCR (Swarm/Portainer faz pull). Tag fixa: :v0.3.0
APP_IMAGE=ghcr.io/gabrielspencerf/observabilidade-saas:latest

# Dominio publico da aplicacao
APP_HOST=app.vysen.com.br
NEXT_PUBLIC_APP_URL=https://app.vysen.com.br

# Timezone
TZ=America/Sao_Paulo

# [LEGADO/DEV] Segredos sensíveis — em Swarm vêm de Docker secrets (ver topo).
# Deixar em branco em deploys Swarm; o entrypoint preenche a partir de /run/secrets/*.
POSTGRES_PASSWORD=
SESSION_SECRET=

# Feature flags (autenticacao)
AUTH_PASSWORD_RESET_ENABLED=false
AUTH_GOOGLE_LOGIN_ENABLED=false
AUTH_REMEMBER_ME_ENABLED=true
NEXT_PUBLIC_AUTH_PASSWORD_RESET_ENABLED=false
NEXT_PUBLIC_AUTH_GOOGLE_LOGIN_ENABLED=false
NEXT_PUBLIC_AUTH_REMEMBER_ME_ENABLED=true

# Sessao e reset
AUTH_DEFAULT_SESSION_TTL_SECONDS=28800
AUTH_REMEMBER_ME_TTL_SECONDS=2592000
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# [LEGADO/DEV] Criptografia (32 bytes = 64 caracteres hex).
# Em Swarm, vêm dos Docker secrets config_encryption_key / integrations_encryption_key.
CONFIG_ENCRYPTION_KEY=
INTEGRATIONS_ENCRYPTION_KEY=

# OpenAI (opcional; transcrição Whisper e Vision)
OPENAI_API_KEY=
# Vysen Copilot (roteamento de modelo)
OPENAI_MODEL_THINKING=gpt-5.4-thinking
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_FALLBACK_ENABLED=true
OPENAI_THINKING_TIMEOUT_MS=30000

# SMTP — mesmo remetente/credenciais já usados (hub@creativelane.io).
# App pública pode ser outro dominio (ex.: app.vysen.com.br); SPF/DKIM seguem o dominio do servidor de e-mail.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hub@creativelane.io
SMTP_PASS=
SMTP_FROM=hub@creativelane.io
SMTP_REPLY_TO=hub@creativelane.io

# Compatibilidade (formato estilo Chatwoot/Rails) - opcional
MAILER_SENDER_EMAIL=hub@creativelane.io <hub@creativelane.io>
SMTP_DOMAIN=creativelane.io
SMTP_ADDRESS=smtp.gmail.com
SMTP_SSL=false
SMTP_USERNAME=hub@creativelane.io
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer
MAILER_INBOUND_EMAIL_DOMAIN=creativelane.io

# Google Login (OAuth invite-only)
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=
GOOGLE_AUTH_STATE_SECRET=

# Google Ads (opcionais; preencher quando ativar)
GOOGLE_ADS_CONNECT_ENABLED=false
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_URI=
GOOGLE_ADS_ENCRYPTION_KEY=
GOOGLE_ADS_STATE_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Seed: primeiro admin (login em /admin-login).
# [LEGADO/DEV] SEED_ADMIN_PASSWORD vem do Docker secret seed_admin_password em Swarm.
SEED_ADMIN_PASSWORD=
SEED_ADMIN_EMAIL=admin@exemplo.com

# Seed opcional de integracoes (Typebot / Evolution)
SEED_TYPEBOT_EXTERNAL_ID=
SEED_TYPEBOT_NAME=
SEED_TYPEBOT_API_TOKEN=
SEED_TYPEBOT_WEBHOOK_SECRET=
SEED_TYPEBOT_METRICS_API_BASE_URL=
SEED_EVOLUTION_EXTERNAL_ID=
SEED_EVOLUTION_INSTANCE_NAME=
SEED_EVOLUTION_BASE_URL=
SEED_EVOLUTION_API_KEY=

# Traefik
TRAEFIK_CERTRESOLVER=letsencryptresolver

# Escala
WEB_REPLICAS=1
WORKER_REPLICAS=1

# Limites de recursos
WEB_CPU_LIMIT=1.0
WEB_MEMORY_LIMIT=1024M
WORKER_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=1024M
POSTGRES_CPU_LIMIT=0.75
POSTGRES_MEMORY_LIMIT=768M
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_LIMIT=512M

# Volumes externos
POSTGRES_VOLUME_NAME=vysen_postgres_data
REDIS_VOLUME_NAME=vysen_redis_data

# Backup e snapshot (operacao no VPS)
BACKUP_DIR=/var/backups/observabilidade
BACKUP_RETENTION_DAYS=14
SNAPSHOT_RETENTION_DAYS=7
POSTGRES_SERVICE=observabilidade_postgres
POSTGRES_DB=vysen
POSTGRES_USER=postgres
